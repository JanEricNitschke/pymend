 def fully_typed(x: int, y: str) -> bool:
     """All types present in signature and docstring.
 
-    Parameters
-    ----------
-    x : int
-        First param.
-    y : str
-        Second param.
+    Args:
+        x (int): First param.
+        y (str): Second param.
 
-    Returns
-    -------
-    bool
-        The result.
+    Returns:
+        bool: The result.
     """
     return x > 0
 
