 def no_docstring_typed(x: int) -> str:
+    """_summary_.
+
+    Args:
+        x (int): _description_
+
+    Returns:
+        str: _description_
+    """
     return "hello"
 
 
 def no_docstring_untyped(x):
+    """_summary_.
+
+    Args:
+        x (_type_): _description_
+
+    Returns:
+        _type_: _description_
+    """
     return x
 
 
 def named_return_typed(x: int) -> bool:
     """Function with named return type.
 
-    Parameters
